within Pharmacolibrary.Icons;
model BloodPlasma
equation

  annotation(
    Icon(graphics = {Rectangle(origin = {0, -2}, fillColor = {255, 0, 0}, fillPattern = FillPattern.Solid, extent = {{-96, 10}, {96, -10}}), Text(origin = {-1, 30}, extent = {{-133, 18}, {133, -18}}, textString = "%name"), Text(origin = {-4, -39}, extent = {{-130, 19}, {130, -19}}, textString = "V=%V")}));
end BloodPlasma;